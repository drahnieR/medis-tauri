{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medis Tauri",
  "version": "1.0.3",
  "identifier": "li.zihua.medis-tauri",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Medis",
        "width": 960,
        "height": 600,
        "minWidth": 840,
        "minHeight": 400,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
